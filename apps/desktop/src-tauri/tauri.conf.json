{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workspace Terminal",
  "version": "0.5.0",
  "identifier": "com.futureteam.workspace-terminal",
  "build": {
    "beforeDevCommand": "npm run dev --workspace apps/ui",
    "beforeBuildCommand": "npm run build --workspace apps/ui",
    "frontendDist": "../../ui/dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Vantara",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
